{
  "layer": "top",
  "position": "top",
  "modules-left": [
    "ext/workspaces"
  ],
  "modules-center": [
  ],
  "modules-right": [
    "tray",
    "idle_inhibitor",
    "wireplumber",
    "backlight",
    "bluetooth",
    "network",
    "battery",
    "clock"
  ],
  "ext/workspaces": {
    "on-click": "activate",
    "sort-by-number": true
  },
  "tray": {
    "icon-size": 17,
    "spacing": 10
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "ΎΒχ",
      "deactivated": "ΎΒ░"
    }
  },
  "wireplumber": {
    "format": "{icon}",
    "format-muted": "≤░ζθ",
    "tooltip-format": "{volume}%",
    "on-click": "pavucontrol",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "format-icons": [
      "ΎΑο",
      "ΎΑπ",
      "ΎΑρ"
    ]
  },
  "backlight": {
    "format": "{icon}",
    "tooltip-format": "{percent}%",
    "format-icons": [
      "ΌΟΞ",
      "ΌΠΥ",
      "ΌΠΣ",
      "ΌΠΠ",
      "ΌΠΟ",
      "ΌΠΞ",
      "ΌΠΛ",
      "ΌΠΙ",
      "ΌΟδ"
    ],
    "on-scroll-up": "brightnessctl set +1%",
    "on-scroll-down": "brightnessctl set 1%-"
  },
  "bluetooth": {
    "format": "≤░Γψ",
    "on-click": "blueman-manager",
    "on-click-right": "bluetooth toggle",
    "tooltip-format": "{status}",
    "tooltip-format-disabled": "disabled",
    "tooltip-format-on": "enabled",
    "tooltip-format-off": "disabled"
  },
  "network": {
    "format": "ΎΘτ",
    "format-wifi": "ΎΘτ",
    "format-ethernet": "ΎΘτ",
    "format-disconnected": "≤░ΙΓ",
    "tooltip-format": "{ipaddr}",
    "tooltip-format-wifi": "{ipaddr}/{cidr} | {ifname} | {essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "{ipaddr}/{cidr} | {ifname}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50
  },
  "battery": {
    "interval": 60,
    "states": {
      "warning": 30,
      "critical": 5
    },
    "format": "{icon}",
    "format-charging": "≤░ΓΕ",
    "tooltip-format": "{capacity}% | {timeTo}",
    "format-icons": [
      "≤░ΓΔ",
      "≤░Β║",
      "≤░Β╗",
      "≤░Β╝",
      "≤░Β╜",
      "≤░Β╛",
      "≤░Β╛",
      "≤░Β┐",
      "≤░ΓΒ",
      "≤░ΓΓ",
      "≤░Β╣"
    ],
    "max-length": 25
  },
  "clock": {
    "interval": 60,
    "format": "{:%H:%M}",
    "tooltip-format": "{:%d/%m/%y}",
    "max-length": 25
  }
}

